# OpenClaw .env example for FORTE
#
# Quick start:
# 1) Copy this file to `openclaw_config/.env` (gitignored).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=<paste-your-gateway-token>
# Example generator: openssl rand -hex 32

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# -----------------------------------------------------------------------------
# AI agent provider API keys
# The keys must correspond to the provider used in openclaw_config/openclaw.json.
# The shipped example uses OpenRouter as the agent gateway.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# LLM judge — OpenAI-compatible gateway.
# call_api reads these three from the process env; benchmark.py bridges them
# from this file. JUDGE_MODEL takes precedence over the CLI/default judge model.
# -----------------------------------------------------------------------------
# Base URL of an OpenAI-compatible gateway; "/chat/completions" is appended.
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=sk-or-...
JUDGE_MODEL=google/gemini-3-flash-preview

# -----------------------------------------------------------------------------
# Tools (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
